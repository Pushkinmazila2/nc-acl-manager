# Nextcloud 34 настройки
NEXTCLOUD_URL=https://your-nextcloud.com
APP_SECRET=generate-random-secret-here

# Windows Agent настройки
AGENT_URL=https://10.0.1.50:8443
AGENT_BEARER_TOKEN=your-agent-bearer-token
AGENT_CERT_PASSWORD=your-cert-password

# Путь к сертификату на хосте (для docker volume)
HOST_CERT_PATH=/path/to/client.pfx
